<!-- INICIO - MisiГіn 1: IntroducciГіn -->
<div *ngIf="labId === '1'" class="lab-content">

  <!-- ============================================================
       HERO INMERSIVO  PartГӯculas flotantes + tГӯtulo animado
  ============================================================ -->
  <div class="m1-hero glass-panel">
    <!-- PartГӯculas de fondo (CSS puro) -->
    <div class="m1-particles" aria-hidden="true">
      <span class="m1-p m1-p1">X</span>
      <span class="m1-p m1-p2">Y</span>
      <span class="m1-p m1-p3">Z</span>
      <span class="m1-p m1-p4">A</span>
      <span class="m1-p m1-p5">B</span>
      <span class="m1-p m1-p6">C</span>
    </div>

    <div class="m1-hero-body">
      <div class="m1-hero-left">
        <div class="m1-mГЎssion-badge">
          <span class="m1-badge-num">01</span>
          <span class="m1-badge-label">MISIГғВ“N</span>
        </div>
        <h2 class="m1-hero-title">IntroducciГіn a la<br><span class="m1-title-accent">Realidad Aumentada</span></h2>
        <p class="m1-hero-sub">
          Descubre la tecnologГӯa que fusiona el mundo fГӯsico con el digital<br>
          y transforma para siempre la forma de enseГұar y aprender.
        </p>

        <!-- Chips de objetivos -->
        <div class="m1-chip-row">
          <span class="m1-chip">Вӯ ВҝQuГ© es la RA?</span>
          <span class="m1-chip"> RA vs RV vs RM</span>
          <span class="m1-chip"> RA en el aula</span>
          <span class="m1-chip"> Ruta de 7 misiones</span>
          <span class="m1-chip"> Trofeos &amp; Coleccionables</span>
        </div>
      </div>

      <!-- AR Visor animado -->
      <div class="m1-ar-visor" aria-hidden="true">
        <div class="m1-visor-frame">
          <div class="m1-visor-scan"></div>
          <div class="m1-visor-corner tl"></div>
          <div class="m1-visor-corner tr"></div>
          <div class="m1-visor-corner bl"></div>
          <div class="m1-visor-corner br"></div>
          <div class="m1-visor-center">
            <div class="m1-orbit">
              <div class="m1-orbit-ring r1"></div>
              <div class="m1-orbit-ring r2"></div>
              <div class="m1-orbit-ring r3"></div>
              <div class="m1-planet"> De </div>
            </div>
          </div>
          <div class="m1-visor-hud">
            <span class="m1-hud-dot"></span> AR ACTIVO
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ============================================================
       ВҝQUГғВү ES LA RA?  DefiniciГіn visual + comparativa RA/RV/RM
  ============================================================ -->
  <div class="section-title">
    <h3>ВҝQuГ© es la Realidad Aumentada?</h3>
    <div class="title-line"></div>
  </div>

  <!-- DefiniciГіn destacada -->
  <div class="m1-definition-card glass-panel">
    <div class="m1-def-icon">Г°ВҹВ“ВЎ</div>
    <div class="m1-def-text">
      <p class="m1-def-main">
        La <strong>Realidad Aumentada</strong> superpone capas de contenido digital en imГЎgenes,
        modelos 3D, sonidos, datos en tiempo real sobre el mundo fГӯsico que nos rodea,
        a travГ©s de la cГЎmara de un dispositivo. El usuario <em>nunca pierde de vista su entorno real</em>:
        simplemente lo ve enriquГ©cido con informaciГіn digital exactamente posicionada.
      </p>
      <p class="m1-def-examples">
        <strong>Ejemplos cotidianos que ya conoces:</strong>
        filtros de Instagram В· PokГ©mon GO В· IKEA Place В· Google Translate con cГЎmara В· Snapchat Lens
      </p>
    </div>
  </div>

  <!-- Comparativa RA / RV / RM en tarjetas visuales -->
  <div class="m1-spectrum-grid">
    <div class="m1-spectrum-card glass-panel m1-card-ra">
      <div class="m1-sc-icon">Г°ВҹВ‘ВҒГҜВёВҸ</div>
      <div class="m1-sc-badge">RA</div>
      <h4>Realidad Aumentada</h4>
      <p>El mundo real <strong>visible</strong> + capas digitales superpuestas. El dispositivo es una ventana quГ©
        enriquГ©ce la realidad.</p>
      <div class="m1-sc-bar">
        <span class="m1-sc-bar-fill" style="width:40%"></span>
        <span class="m1-sc-bar-label">Digital</span>
      </div>
      <div class="m1-sc-bar real">
        <span class="m1-sc-bar-fill" style="width:100%"></span>
        <span class="m1-sc-bar-label">Real</span>
      </div>
    </div>

    <div class="m1-spectrum-card glass-panel m1-card-rm">
      <div class="m1-sc-icon">Г°ВҹВ”ВҖ</div>
      <div class="m1-sc-badge">RM</div>
      <h4>Realidad Mixta</h4>
      <p>Los objetos digitales <strong>interactГәan</strong> con superficies fГӯsicas reales. Mayor precisiГіn espacial.
        Requiere dispositivos especializados.</p>
      <div class="m1-sc-bar">
        <span class="m1-sc-bar-fill" style="width:65%"></span>
        <span class="m1-sc-bar-label">Digital</span>
      </div>
      <div class="m1-sc-bar real">
        <span class="m1-sc-bar-fill" style="width:65%"></span>
        <span class="m1-sc-bar-label">Real</span>
      </div>
    </div>

    <div class="m1-spectrum-card glass-panel m1-card-rv">
      <div class="m1-sc-icon">Г°ВҹВҘВҪ</div>
      <div class="m1-sc-badge">RV</div>
      <h4>Realidad Virtual</h4>
      <p>Entorno 100% digital. El usuario estГЎ <strong>completamente inmerso</strong> en un mundo generado por
        computadora. Requiere casco o visor.</p>
      <div class="m1-sc-bar">
        <span class="m1-sc-bar-fill" style="width:100%"></span>
        <span class="m1-sc-bar-label">Digital</span>
      </div>
      <div class="m1-sc-bar real">
        <span class="m1-sc-bar-fill" style="width:0%"></span>
        <span class="m1-sc-bar-label">Real</span>
      </div>
    </div>
  </div>

  <!-- ============================================================
       ВҝCГғВ“MO FUNCIONA?  Pipeline visual paso a paso
  ============================================================ -->
  <div class="section-title">
    <h3>ВҝCГіmo funciona la RA?  El pipeline de 3 pasos</h3>
    <div class="title-line"></div>
  </div>

  <div class="m1-pipeline glass-panel">
    <div class="m1-pipe-step">
      <div class="m1-pipe-icon">Г°ВҹВ“В·</div>
      <div class="m1-pipe-num">01</div>
      <h4>Captura</h4>
      <p>La cГЎmara del dispositivo captura el entorno fГӯsico en tiempo real, fotograma a fotograma.</p>
    </div>
    <div class="m1-pipe-arrow">ГўВҶВ’</div>
    <div class="m1-pipe-step">
      <div class="m1-pipe-icon">Г°ВҹВ§В </div>
      <div class="m1-pipe-num">02</div>
      <h4>Reconocimiento</h4>
      <p>El software detecta marcadores visuales, superficies planas o espacio 3D y calcula posiciГіn exacta.</p>
    </div>
    <div class="m1-pipe-arrow">ГўВҶВ’</div>
    <div class="m1-pipe-step">
      <div class="m1-pipe-icon">Г°ВҹВ–ВҘГҜВёВҸ</div>
      <div class="m1-pipe-num">03</div>
      <h4>SuperposiciГіn</h4>
      <p>El objeto digital se renderiza con perspectiva correcta sobre la imagen real, 60 veces por segundo.</p>
    </div>
  </div>

  <!-- ============================================================
       ВҝPOR QUГғВү RA EN EL AULA?  Stats + beneficios
  ============================================================ -->
  <div class="section-title">
    <h3>La RA en la EducaciГіn: Evidencia y Beneficios</h3>
    <div class="title-line"></div>
  </div>

  <div class="m1-stats-row">
    <div class="glass-panel m1-stat-card">
      <div class="m1-stat-num">75%</div>
      <p>mГЎs retenciГіn de informaciГіn frente al aprendizaje pasivo expositivo</p>
    </div>
    <div class="glass-panel m1-stat-card">
      <div class="m1-stat-num">3ГғВ—</div>
      <p>mayor motivaciГіn reportada por estudiantes en clases con tecnologГӯas inmersivas</p>
    </div>
    <div class="glass-panel m1-stat-card">
      <div class="m1-stat-num">KГўВҖВ“12</div>
      <p>la RA es efectiva en todos los niveles educativos, desde primaria hasta universitario</p>
    </div>
    <div class="glass-panel m1-stat-card">
      <div class="m1-stat-num">$0</div>
      <p>costo de las herramientas base de este curso. EducaciГіn inmersiva accesible para todos</p>
    </div>
  </div>

  <div class="m1-benefits-grid">
    <div class="glass-panel m1-benefit">
      <span class="m1-ben-icon">Г°ВҹВ§В </span>
      <div>
        <h4>Multisensorial</h4>
        <p>Activa canales visuales, auditivos y cinestГ©sicos simultГЎneamente, potenciando la retenciГіn a largo plazo.
        </p>
      </div>
    </div>
    <div class="glass-panel m1-benefit">
      <span class="m1-ben-icon">Г°ВҹВҺВ®</span>
      <div>
        <h4>Aprendizaje activo</h4>
        <p>El estudiante manipula, explora y descubre en lugar de recibir informaciГіn pasivamente.</p>
      </div>
    </div>
    <div class="glass-panel m1-benefit">
      <span class="m1-ben-icon">Г°ВҹВ‘ВҒГҜВёВҸ</span>
      <div>
        <h4>Conceptos abstractos visibles</h4>
        <p>MolГ©culas, Гіrganos, astros, procesos geolГіgicos o ecuaciones cobran vida en el espacio fГӯsico del aula.</p>
      </div>
    </div>
    <div class="glass-panel m1-benefit">
      <span class="m1-ben-icon">Г°ВҹВҢВҚ</span>
      <div>
        <h4>Sin barreras geogrГЎficas</h4>
        <p>Un volcГЎn del PacГӯfico, la Torre Eiffel o el interior de una cГ©lula pueden estar sobre tu escritorio hoy.</p>
      </div>
    </div>
  </div>

  <!-- ============================================================
       RUTA DE APRENDIZAJE  Mapa de 7 misiones
  ============================================================ -->
  <div class="section-title">
    <h3>Tu Ruta de Aprendizaje en RaInClass</h3>
    <div class="title-line"></div>
  </div>

  <div class="glass-panel m1-roadmap-panel">
    <p class="m1-roadmap-intro">
      ExplorarГЎs <strong>7 misiones progresivas</strong>. Cada una introduce una herramienta o concepto diferente.
      Al completar la evaluaciГіn de cada misiГіn, desbloquГ©as la siguiente y acumulas <strong>XP y Trofeos</strong>.
    </p>
    <div class="m1-roadmap">
      <div class="m1-rm-item m1-rm-active">
        <div class="m1-rm-dot active"></div>
        <div class="m1-rm-card glass-panel">
          <span class="m1-rm-num">01</span>
          <span class="m1-rm-icon">Г°ВҹВҺВҜ</span>
          <h4>IntroducciГіn a la RA</h4>
          <p>Fundamentos, diferencias RA/RV/RM y ruta de aprendizaje. <em>ГўВҶВҗ EstГЎs aquГӯ</em></p>
        </div>
      </div>
      <div class="m1-rm-connector"></div>
      <div class="m1-rm-item">
        <div class="m1-rm-dot"></div>
        <div class="m1-rm-card glass-panel">
          <span class="m1-rm-num">02</span>
          <span class="m1-rm-icon">Г°ВҹВ§ВҠ</span>
          <h4>Merge Cube</h4>
          <p>SostГ©n objetos 3D digitales en tu mano con un cubo fГӯsico de marcadores AR.</p>
        </div>
      </div>
      <div class="m1-rm-connector"></div>
      <div class="m1-rm-item">
        <div class="m1-rm-dot"></div>
        <div class="m1-rm-card glass-panel">
          <span class="m1-rm-num">03</span>
          <span class="m1-rm-icon">Г°ВҹВҺВЁ</span>
          <h4>QuiverVision</h4>
          <p>Da vida en 3D a pГЎginas para colorear: actividad manual que se vuelve digital.</p>
        </div>
      </div>
      <div class="m1-rm-connector"></div>
      <div class="m1-rm-item">
        <div class="m1-rm-dot"></div>
        <div class="m1-rm-card glass-panel">
          <span class="m1-rm-num">04</span>
          <span class="m1-rm-icon">Г°ВҹВ—ВәГҜВёВҸ</span>
          <h4>Actionbound</h4>
          <p>Recorridos gamificados, bГәsquedas del tesoro y aventuras con geolocalizaciГіn.</p>
        </div>
      </div>
      <div class="m1-rm-connector"></div>
      <div class="m1-rm-item">
        <div class="m1-rm-dot"></div>
        <div class="m1-rm-card glass-panel">
          <span class="m1-rm-num">05</span>
          <span class="m1-rm-icon">Г°ВҹВҢВҗ</span>
          <h4>Metaverso Meta</h4>
          <p>Colabora y aprende en entornos virtuales inmersivos accesibles desde el navegador.</p>
        </div>
      </div>
      <div class="m1-rm-connector"></div>
      <div class="m1-rm-item">
        <div class="m1-rm-dot"></div>
        <div class="m1-rm-card glass-panel">
          <span class="m1-rm-num">06</span>
          <span class="m1-rm-icon">Г°ВҹВ”В¬</span>
          <h4>Visualizador de Modelos 3D</h4>
          <p>Crea y visualiza tus propios modelos 3D en RA desde cualquier asignatura.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- ============================================================
       TROFEOS Y COLECCIONABLES  Sistema de recompensas
  ============================================================ -->
  <div class="section-title">
    <h3>Г°ВҹВҸВҶ Trofeos &amp; Coleccionables  Tu Sistema de Recompensas</h3>
    <div class="title-line"></div>
  </div>

  <div class="m1-rewards-hero glass-panel">
    <div class="m1-rh-left">
      <p class="m1-rh-intro">
        RaInClass convierte tu proceso de aprendizaje en una <strong>aventura de colecciГіn</strong>.
        Cada evaluaciГіn superada te entrega un <strong>Trofeo</strong> segГәn tu desempeГұo,
        y cada misiГіn completada desbloquГ©a <strong>Coleccionables</strong> Гәnicos que forman
        tu galerГӯa personal de logros.
      </p>
    </div>
    <div class="m1-rh-right">
      <div class="m1-rh-medals">
        <div class="m1-rh-medal platinum">
          <span class="m1-rh-emoji">Г°ВҹВ’ВҺ</span>
          <span class="m1-rh-name">Platino</span>
          <span class="m1-rh-pct">100%</span>
        </div>
        <div class="m1-rh-medal gold">
          <span class="m1-rh-emoji">Г°ВҹВҘВҮ</span>
          <span class="m1-rh-name">Oro</span>
          <span class="m1-rh-pct">ГўВүВҘ 90%</span>
        </div>
        <div class="m1-rh-medal silver">
          <span class="m1-rh-emoji">Г°ВҹВҘВҲ</span>
          <span class="m1-rh-name">Plata</span>
          <span class="m1-rh-pct">ГўВүВҘ 80%</span>
        </div>
        <div class="m1-rh-medal bronze">
          <span class="m1-rh-emoji">Г°ВҹВҘВү</span>
          <span class="m1-rh-name">Bronce</span>
          <span class="m1-rh-pct">ГўВүВҘ 70%</span>
        </div>
      </div>
    </div>
  </div>

  <div class="m1-rewards-detail">
    <div class="glass-panel m1-reward-box">
      <div class="m1-rb-header">
        <span class="m1-rb-icon">Г°ВҹВҸВҶ</span>
        <h4>Trofeos por MisiГіn</h4>
      </div>
      <p>
        Al aprobar la evaluaciГіn de cada misiГіn obtienes un trofeo segГәn tu puntaje:
        <strong>Bronce</strong> (70ГўВҖВ“79%), <strong>Plata</strong> (80ГўВҖВ“89%), <strong>Oro</strong> (90ГўВҖВ“99%)
        o el codiciado <strong>Platino</strong> (100% perfecto).
      </p>
      <p>Puedes reintentar la evaluaciГіn para mejorar tu trofeo cuando quieras.
        <strong>Solo se guarda tu mejor resultado</strong>.
      </p>
      <div class="m1-tip-inline">Г°ВҹВ’ВЎ Ve a la secciГіn <strong>Trofeos</strong> del menГә para ver tu colecciГіn completa
        en todo momento.</div>
    </div>

    <div class="glass-panel m1-reward-box">
      <div class="m1-rb-header">
        <span class="m1-rb-icon">Г°ВҹВғВҸ</span>
        <h4>Coleccionables Digitales</h4>
      </div>
      <p>
        Cada misiГіn tiene asociados <strong>coleccionables desbloquГ©ables</strong>: insignias,
        tarjetas temГЎticas y objetos AR Гәnicos. Se desbloquean al completar actividades especГӯficas
        dentro de la misiГіn.
      </p>
      <p>Tu galerГӯa de coleccionables es <strong>Гәnica y personal</strong>.
        Forma tu colecciГіn completa explorando a fondo cada misiГіn.</p>
      <div class="m1-tip-inline">Г°ВҹВ’ВЎ Consulta la secciГіn <strong>Coleccionables</strong> del menГә para ver que ya
        tienes y que te falta.</div>
    </div>
  </div>

  <!-- ============================================================
       CALL TO ACTION  PrГіximo paso
  ============================================================ -->
  <div class="m1-cta glass-panel">
    <div class="m1-cta-icon">Г°ВҹВҡВҖ</div>
    <div class="m1-cta-text">
      <h3>ВҝListo para profundizar?</h3>
      <p>
        AsegГәrate de tener un <strong>dispositivo con cГЎmara</strong> (telГ©fono, tablet o PC con webcam)
        y conexiГіn a internet estable. Luego avanza a la pestaГұa <strong>Desarrollo</strong>
        para explorar los conceptos con mГЎs detalle y ejemplos prГЎcticos,
        o ve directamente a <strong>EvaluaciГіn</strong> si ya dominas el tema.
      </p>
    </div>
  </div>

</div>
<!-- INICIO - MisiГіn 2: Merge Cube (antiguo Lab 1) -->
<div *ngIf="labId === '2'" class="lab-content">

  <!-- Hero Section -->
  <div class="hero-section glass-panel">
    <div class="hero-text">
      <h2>MisiГіn 2: Merge Cube</h2>
      <p class="subtitle">SostГ©n el universo en la palma de tu mano</p>
      <p>
        El <strong>Merge Cube</strong> es un cubo fГӯsico de realidad aumentada que convierte un
        dispositivo mГіvil corriente en una ventana hacia objetos digitales 3D interactivos. Al
        sostenerlo frente a la cГЎmara, el cubo parece desaparecer y en su lugar aparece flotando
        sobre tus manos un planeta, una cГ©lula, una molГ©cula o cualquier modelo que la aplicaciГіn
        active. No se necesita hardware costoso: un smartphone, una tableta o incluso el cubo impreso
        en papel son suficientes para comenzar.
      </p>
      <p>
        En esta misiГіn conocerГЎs <strong>que es, cГіmo funciona y por que el Merge Cube se ha
          convertido en una de las herramientas de realidad aumentada mГЎs adoptadas en la educaciГіn
          STEM</strong> a nivel mundial.
      </p>
    </div>
    <div class="hero-image">
      <div class="merge-cube-3d">
        <div class="mc-face mc-front">
          <div class="mc-pattern"></div>
        </div>
        <div class="mc-face mc-back">
          <div class="mc-pattern"></div>
        </div>
        <div class="mc-face mc-right">
          <div class="mc-pattern"></div>
        </div>
        <div class="mc-face mc-left">
          <div class="mc-pattern"></div>
        </div>
        <div class="mc-face mc-top">
          <div class="mc-pattern"></div>
        </div>
        <div class="mc-face mc-bottom">
          <div class="mc-pattern"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Conceptos clave -->
  <div class="section-title">
    <h3>Conceptos Clave</h3>
    <div class="title-line"></div>
  </div>

  <div class="info-grid">
    <div class="glass-panel info-card">
      <h3>ВҝQuГ© es el Merge Cube?</h3>
      <p>
        Es un cubo de gomaespuma de ~7 cm de lado con <strong>patrones geomГ©tricos Гәnicos</strong>
        impresos en cada cara. Esos patrones actГәan cГіmo <em>marcadores de RA</em>: la cГЎmara del
        dispositivo los detecta, calcula posiciГіn y orientaciГіn del cubo en tiempo real, y superpone
        un objeto 3D interactivo exactamente donde estГЎ el cubo fГӯsico.
      </p>
    </div>

    <div class="glass-panel info-card">
      <h3>TecnologГӯa detrГЎs del cubo</h3>
      <ul>
        <li><strong>VisiГіn por computadora:</strong> algoritmГЎs que identifican y rastrean los patrones del cubo en cada
          fotograma de video.</li>
        <li><strong>Seguimiento espacial (tracking):</strong> calcula distancia, ГЎngulo y rotaciГіn para anclar el modelo
          3D con precisiГіn.</li>
        <li><strong>Renderizado en tiempo real:</strong> el objeto digital se actualiza ~60 veces por segundo, creando
          la ilusiГіn de un holograma sГіlido.</li>
      </ul>
    </div>

    <div class="glass-panel info-card">
      <h3>Merge Cube vs. otras tecnologГӯas inmersivas</h3>
      <ul>
        <li>Г°ВҹВҹВў <strong>RA con Merge Cube:</strong> el usuario ve su entorno real + el objeto 3D sobrepuesto.
          InteracciГіn tГЎctil y fГӯsica con el cubo.</li>
        <li>Г°ВҹВ”Вө <strong>Realidad Virtual (RV):</strong> entorno completamente digital, el usuario se aГӯsla del mundo
          real. Requiere cascos.</li>
        <li>Г°ВҹВҹВЎ <strong>Realidad Mixta (RM):</strong> los objetos digitales interactГәan con superficies fГӯsicas reales.
          Hardware mГЎs especializado.</li>
      </ul>
    </div>

    <div class="glass-panel info-card">
      <h3>ВҝPor que es relevante en educaciГіn?</h3>
      <ul>
        <li>Г°ВҹВ§В  Activar la manipulaciГіn fГӯsica <em>y</em> la visualizaciГіn digital simultГЎneamente potencia la
          retenciГіn y comprensiГіn.</li>
        <li>Г°ВҹВҺВ® La novedad tecnolГіgica eleva la motivaciГіn intrГӯnseca del estudiante.</li>
        <li>Г°ВҹВ‘ВҒГҜВёВҸ Hace tangible lo invisible: ГЎtomГЎs, cГ©lulas, astros, capas geolГіgicas.</li>
        <li>Г°ВҹВ’Вё Costo casi nulo: la plantilla del cubo es gratuita y descargable; solo se necesita impresora y tijeras.
        </li>
      </ul>
    </div>
  </div>

  <!-- CГіmo funciona paso a paso -->
  <div class="section-title">
    <h3>ВҝCГіmo Funciona?  Paso a Paso</h3>
    <div class="title-line"></div>
  </div>

  <div class="how-it-works glass-panel">
    <div class="steps-container">
      <div class="step">
        <div class="step-number">1</div>
        <h4>ObtГ©n o imprime el cubo</h4>
        <p>Adquiere el cubo merge fГӯsico (gomaespuma) o descarga la <strong>plantilla gratuita</strong> en <a
            href="https://mergeedu.com/cube" target="_blank">mergeedu.com/cube</a>, imprГӯmela y arma el cubo con tijeras
          y pegamento.</p>
      </div>
      <div class="step-arrow">ГўВҶВ’</div>
      <div class="step">
        <div class="step-number">2</div>
        <h4>Descarga una app compatible</h4>
        <p>Instala <strong>Merge Explorer</strong>, <strong>Object Viewer</strong> o <strong>HoloGlobe</strong> desde la
          App Store, Google Play o la tienda de Chromebook. Todas son gratuitas en su versiГіn bГЎsica.</p>
      </div>
      <div class="step-arrow">ГўВҶВ’</div>
      <div class="step">
        <div class="step-number">3</div>
        <h4>Enfoca el cubo con la cГЎmara</h4>
        <p>Abre la app y apunta la cГЎmara al cubo. El sistema reconoce los patrones y proyecta el objeto 3D sobre el
          cubo en la pantalla en tiempo real.</p>
      </div>
      <div class="step-arrow">ГўВҶВ’</div>
      <div class="step">
        <div class="step-number">4</div>
        <h4>Explora e interactГәa</h4>
        <p>Gira, inclina y acerca el cubo fГӯsico. El modelo 3D se mueve de forma sincronizada. Toca la pantalla para
          activar capas de informaciГіn, animaciГіnes o datos adicionales.</p>
      </div>
    </div>
    <div class="howto-image">
      <img src="assets/images/labs/merge_cube_howto.png" alt="CГіmo funciona el Merge Cube">
    </div>
  </div>

  <!-- Aplicaciones educativas -->
  <div class="section-title">
    <h3>Aplicaciones Educativas por ГғВҒrea</h3>
    <div class="title-line"></div>
  </div>

  <div class="apps-grid">
    <div class="glass-panel app-card">
      <div class="app-icon">Г°ВҹВӘВҗ</div>
      <h4>AstronomГӯa y Ciencias del Espacio</h4>
      <p>SostГ©n planetas, lunas, cometas y nebulosas en tu mano. Comprende escalas, Гіrbitas y composiciГіn de los cuerpos
        celestes de forma vivencial.</p>
    </div>
    <div class="glass-panel app-card">
      <div class="app-icon">Г°ВҹВ§В¬</div>
      <h4>BiologГӯa y Ciencias Naturales</h4>
      <p>Examina cГ©lulas, disecciona organismГЎs virtualmente, explora Гіrganos del cuerpo humano y comprende procesos
        biolГіgicos complejos en 3D.</p>
    </div>
    <div class="glass-panel app-card">
      <div class="app-icon">ГўВҡВ—ГҜВёВҸ</div>
      <h4>QuГӯmica</h4>
      <p>Visualiza y rota molГ©culas de ADN, enlaces covalentes e iГәnicos, y estructuras cristalinas que son imposibles
        de apreciar en un libro plano.</p>
    </div>
    <div class="glass-panel app-card">
      <div class="app-icon">Г°ВҹВҢВӢ</div>
      <h4>GeologГӯa y GeografГӯa</h4>
      <p>Examina el interior de la Tierra por capas, estudia fГіsiles en detalle y comprende procesos tectГәnicos quГ©
        ocurren a escala de millones de aГұos.</p>
    </div>
    <div class="glass-panel app-card">
      <div class="app-icon">Г°ВҹВҺВЁ</div>
      <h4>CreaciГіn y DiseГұo 3D</h4>
      <p>Los estudiantes diseГұan objetos en <strong>Tinkercad</strong> o <strong>Paint 3D</strong> y los ven
        materializados sobre el cubo, cerrando el ciclo diseГұoГўВҖВ“visualizaciГіn.</p>
    </div>
    <div class="glass-panel app-card">
      <div class="app-icon">Г°ВҹВҢВҚ</div>
      <h4>Ciencias Sociales</h4>
      <p><strong>HoloGlobe</strong> convierte el cubo en un globo terrГЎquГ©o hologrГЎfico interactivo: clima, demografГӯa,
        relieve, placas tectГіnicas y mГЎs datos en tiempo real.</p>
    </div>
  </div>

  <!-- EstadГӯsticas -->
  <div class="features-row">
    <div class="glass-panel feature-item">
      <div class="feature-stat">1000+</div>
